# Copy this file to .env and fill in real values for your local machine.
# .env is gitignored and should never be committed.

# Which profile to run (dev | prod)
SPRING_PROFILES_ACTIVE=dev

# App server port
SERVER_PORT=8013

# MySQL connection
DB_HOST=localhost
DB_PORT=3306
DB_NAME=users_db
DB_USERNAME=users_api
DB_PASSWORD=Sushmacg@07

# HikariCP connection pool tuning (optional - sensible defaults exist)
DB_POOL_MAX_SIZE=10
DB_POOL_MIN_IDLE=2
DB_POOL_IDLE_TIMEOUT=30000
DB_POOL_CONNECTION_TIMEOUT=30000
DB_POOL_MAX_LIFETIME=1800000

# JWT signing secret (use a long, random string - at least 32 bytes for HS256)
# Generate one with: openssl rand -base64 32
JWT_SECRET=replace_this_with_a_long_random_secret_value_at_least_32_bytes
# Token lifetime in milliseconds (default: 1 hour)
JWT_EXPIRATION_MS=3600000

# Optional - creates this ADMIN account automatically on first startup
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=ChangeThisPassword123
ADMIN_NAME=Admin
